# Copy this to .env and fill in your values. Never commit .env to git.

# K2-Think-v2 — get your key at https://api.k2think.ai
K2_API_KEY=your-k2-api-key-here

# Gemma via Ollama — no key needed for a local Ollama server.
# GEMMA_BASE_URL and GEMMA_MODEL are set in docker-compose.yml; override here if needed.
# GEMMA_BASE_URL=http://localhost:11434/v1
# GEMMA_MODEL=gemma3:27b

# WebSocket URL — update after Vultr VM is provisioned.
# Used by the Revit plugin (set per machine, not in docker-compose).
# REVITSYNC_WS_URL=ws://<vultr-ip>:8000/ws
# REVITSYNC_SESSION_ID=your-name
